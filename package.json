{
  "name": "acreditacion-risks",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS multitenant de evaluación y certificación de personas bajo ISO/IEC 17024",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "_disabled_postbuild_vercel": "prisma migrate deploy",
    "_disabled_postbuild": "tsx prisma/seed-documentation.ts || echo 'seed-documentation skipped'",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:ocp": "tsx prisma/seed-ocp.ts",
    "db:seed:docs": "tsx prisma/seed-documentation.ts",
    "db:reset": "prisma migrate reset --force",
    "add:uiaf-doc": "tsx prisma/scripts/add-uiaf-required-doc.ts",
    "fix:roe-to-roi": "tsx prisma/scripts/fix-roe-to-roi.ts",
    "sync:stale-enrollments": "tsx prisma/scripts/sync-stale-enrollments.ts",
    "set:attempts": "tsx prisma/scripts/set-attempts-allowed.ts",
    "populate:case-context": "tsx prisma/scripts/populate-case-context.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1059.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@prisma/client": "^6.3.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "jose": "^5.9.6",
    "next": "^15.1.6",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "prisma": "^6.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
