# --- Base de datos ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# --- Seguridad ---
AUTH_SECRET="genera-un-secreto-aleatorio-de-32-o-mas-caracteres"
AUTH_SESSION_TTL_HOURS="12"

# --- App ---
NEXT_PUBLIC_APP_NAME="CIOC"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron (recordatorios de vencimiento) ---
# Si se define, el endpoint /api/cron/reminders exige el header x-cron-secret con este valor.
CRON_SECRET=""

# --- Almacenamiento de archivos (documentos/evidencias) ---
# Sin configurar S3 → usa carpeta local (solo dev): STORAGE_DIR (por defecto storage/uploads).
STORAGE_DIR=""
# Object storage S3-compatible (Railway bucket / S3) — REQUERIDO en producción serverless.
STORAGE_S3_ENDPOINT=""            # p. ej. https://t3.storageapi.dev
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION="auto"
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""
STORAGE_S3_FORCE_PATH_STYLE="false"   # "true" si el proveedor usa path-style

# --- Correo (transaccional) ---
EMAIL_PROVIDER="log"               # log (dev, solo registra) | resend | smtp
EMAIL_FROM="AcreditaPro <no-reply@okacreditado.com>"
# Resend (https://resend.com) — proveedor por API, sin SMTP:
RESEND_API_KEY=""
# SMTP (alternativa clásica):
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"                # "true" para puerto 465
SMTP_USER=""
SMTP_PASS=""

# --- Pagos ---
PAYMENTS_DEFAULT_PROVIDER="mock"   # mock | stripe | wompi
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""
